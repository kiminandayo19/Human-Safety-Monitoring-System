# --- Application ---
APP_NAME="Human Safety Monitoring System"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- CORS (comma-separated or JSON list) ---
CORS_ORIGINS=["*"]

# --- Computer Vision / Detection ---
MODEL_PATH=models/safety_detector.pt
DETECTION_CONFIDENCE_THRESHOLD=0.5
DEVICE=cpu

# --- Safety rules ---
ALERT_CONFIDENCE_THRESHOLD=0.7

# --- Logging ---
LOG_LEVEL=INFO
